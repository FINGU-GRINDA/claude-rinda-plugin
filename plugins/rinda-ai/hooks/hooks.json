{
  "description": "Auto-install rinda-cli binary on session start",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/skills/rinda/scripts/install.sh",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
