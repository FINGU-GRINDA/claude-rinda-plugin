# MCP Server Configuration
PORT=3000
RUST_LOG=info

# RINDA API backend URL
# Use https://alpha.rinda.ai for dev/test (alpha)
# Use https://app.rinda.ai   for beta/prod
RINDA_API_BASE_URL=https://alpha.rinda.ai

# Public URL of this MCP server (used for OAuth callback URLs)
# Must match the actual deployed URL of this MCP instance.
# Examples:
#   Alpha: https://rindamcp-alpha-xxx.sslip.io
#   Beta:  https://rindamcp-beta-xxx.sslip.io
MCP_SERVER_URL=http://localhost:3000
