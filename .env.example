# MCP Server Configuration
PORT=3000
RUST_LOG=info

# RINDA API backend URL
# alpha = dev/test, app = beta/prod
RINDA_API_BASE_URL=https://alpha.rinda.ai

# Public URL of this MCP server
# Used for OAuth callback URLs returned to clients
# Set to your Dokploy domain in production, e.g. https://mcp.rinda.ai
MCP_SERVER_URL=http://localhost:3000
